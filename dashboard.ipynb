import pandas as pd
import matplotlib.pyplot as plt

data = pd.read_csv("sales_data.csv")

plt.figure(figsize=(8,5))
plt.plot(data["Month"], data["Calls"], label="Calls")
plt.plot(data["Month"], data["Conversions"], label="Conversions")
plt.legend()
plt.title("Calls vs Conversions")
plt.show()

plt.bar(data["Month"], data["Revenue"])
plt.title("Monthly Revenue")
plt.show()